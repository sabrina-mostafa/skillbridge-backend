model Availability {
  id       String @id @default(uuid())

  tutorId String
  tutor   TutorProfile @relation(fields: [tutorId], references: [id])

  dayOfWeek Int
  startTime DateTime
  endTime   DateTime
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  bookings Booking[]

  @@index([tutorId])
}